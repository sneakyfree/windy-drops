{
  "name": "@windy/drops-artifact-spec",
  "version": "0.1.0",
  "description": "TypeScript bindings (Zod schemas + types) for the windy.drop.v1 manifest format. Generated from schemas/windy.drop.v1.json — WD-1 of DNA_STRAND_MASTER_PLAN.md.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "codegen": "node codegen.mjs",
    "codegen:check": "node codegen.mjs && git diff --exit-code -- src/index.ts",
    "build": "tsc -p tsconfig.json",
    "test": "node --test tests/*.test.mjs",
    "ci": "npm run codegen:check && npm run build && npm run test",
    "prepublishOnly": "npm run codegen && npm run build"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "json-schema-to-zod": "^2.6.1",
    "@apidevtools/json-schema-ref-parser": "^11.7.0",
    "typescript": "^5.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sneakyfree/windy-drops.git",
    "directory": "packages/artifact-spec"
  }
}
